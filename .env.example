# Copy this file to ".env" and fill in the API keys for the providers you want
# to use in real mode. Mock mode needs NO keys at all.
#
#   cp .env.example .env        (macOS / Linux)
#   copy .env.example .env      (Windows)
#
# NEVER commit your real .env file. It is already in .gitignore.

# --- OpenAI (GPT) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Google (Gemini) ---
# Gemini Enterprise Agent Platform (ADC — no API key)
GOOGLE_GENAI_USE_ENTERPRISE=true
GOOGLE_CLOUD_PROJECT=multi-llm-debate-system
GOOGLE_CLOUD_LOCATION=global
GOOGLE_MODEL=gemini-2.5-flash

# --- xAI (Grok) ---
# xAI exposes an OpenAI-compatible endpoint.
XAI_API_KEY=
XAI_MODEL=grok-3
XAI_BASE_URL=https://api.x.ai/v1
